{
  "version": "1.0.0",
  "created_at": "2026-03-19",
  "description": "执行层技能评测场景库 v1.0 — 10个常用执行层技能",
  "scenarios": [
    {
      "scenario_id": "ex-translate-001",
      "skill_name": "baoyu-translate",
      "display_name": "baoyu-translate（文章翻译）",
      "description": "翻译一篇英文技术文章为中文",
      "prompt": "把这段英文翻译成中文：\n\nThe rise of AI agents represents a fundamental shift in how software interacts with the world. Unlike traditional programs that execute predefined instructions, agents can perceive their environment, make decisions, and take actions to achieve goals. This paradigm shift requires new architectures, new tools, and new ways of thinking about software reliability and safety.",
      "expected_behaviors": [
        "准确翻译技术术语（AI agents / paradigm shift / architecture）",
        "保持原文段落结构",
        "输出流畅的中文，不是机械直译",
        "专业术语可以保留英文或加注"
      ],
      "assertions": [
        {
          "type": "contains",
          "name": "翻译完成-智能体",
          "value": "智能体"
        },
        {
          "type": "contains",
          "name": "关键词翻译-范式",
          "value": "范式"
        },
        {
          "type": "not_contains",
          "name": "不能有原始英文段落",
          "value": "The rise of AI agents represents"
        }
      ],
      "artifact_extractors": [
        {
          "name": "翻译结果",
          "type": "text",
          "description": "最终中文翻译"
        }
      ],
      "source": "skill_definition",
      "priority": "P1",
      "timeout": 120
    },
    {
      "scenario_id": "ex-image-gen-001",
      "skill_name": "baoyu-image-gen",
      "display_name": "baoyu-image-gen（AI生图）",
      "description": "根据描述生成一张技术风格的配图",
      "prompt": "帮我生成一张图：一个AI机器人在和人类程序员一起写代码，科技感，简洁风格，适合博客配图",
      "expected_behaviors": [
        "调用图片生成API",
        "返回可访问的图片URL或本地路径",
        "图片与描述主题相关",
        "生成成功后提供可点击链接"
      ],
      "assertions": [
        {
          "type": "regex",
          "name": "包含图片URL或路径",
          "pattern": "(https?://[^\\s]+\\.(jpg|png|webp)|/Users/[^\\s]+\\.(jpg|png|webp))"
        },
        {
          "type": "contains",
          "name": "调用了生图功能",
          "value": "生成"
        }
      ],
      "artifact_extractors": [
        {
          "name": "生成图片",
          "type": "url",
          "pattern": "https?://[^\\s]+\\.(png|jpg|jpeg|webp)",
          "description": "AI生成的图片链接"
        },
        {
          "name": "本地图片",
          "type": "file",
          "pattern": "/[^\\s]+\\.(png|jpg|jpeg|webp)",
          "description": "本地图片文件"
        }
      ],
      "source": "skill_definition",
      "priority": "P1",
      "timeout": 180
    },
    {
      "scenario_id": "ex-html-screenshot-001",
      "skill_name": "html-screenshot",
      "display_name": "html-screenshot（HTML截图）",
