    {
      "scenario_id": "ex-promotion-review-001",
      "skill_name": "ks-promotion-review-sabcd",
      "display_name": "ks-promotion-review-sabcd（晋升评审）",
      "description": "对一段晋升材料做SABCD评审",
      "prompt": "请帮我对以下晋升材料片段进行评审：\n\n候选人是一名高级工程师，申请P7晋升。主要工作：负责推动研发效能提升项目，将团队需求交付周期从14天缩短到8天，降幅43%。建设了自动化测试体系，单测覆盖率从20%提升到65%。带领3人小团队，培养了2名工程师成长为独立负责人。\n\n请给出SABCD评级和关键改进建议。",
      "expected_behaviors": [
        "输出SABCD其中一个等级",
        "对项目成果有量化评估",
        "指出材料中需要补充的内容",
        "改进建议具体可执行",
        "生成HTML评审报告或结构化输出"
      ],
      "assertions": [
        {
          "type": "regex",
          "name": "包含SABCD评级",
          "pattern": "[SABCD]\\s*[级档]|评级.*[SABCD]|[SABCD].*评级"
        },
        {
          "type": "contains",
          "name": "有改进建议",
          "value": "建议"
        }
      ],
      "artifact_extractors": [
        {
          "name": "评审报告",
          "type": "file",
          "pattern": "/[^\\s]+\\.html",
          "description": "HTML格式评审报告"
        }
      ],
      "source": "skill_definition",
      "priority": "P1",
      "timeout": 180
    },
