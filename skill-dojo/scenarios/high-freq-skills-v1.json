{
  "version": "1.0.0",
  "created_at": "2026-03-21",
  "description": "高频技能精进测试场景（基于调用统计 Top 10）",
  "scenarios": [
    {
      "scenario_id": "hf-internet-research-001",
      "skill_name": "internet-content-research",
      "display_name": "internet-content-research（多平台调研）",
      "description": "微信公众号搜索测试",
      "prompt": "[测试模式] 请使用 internet-content-research 技能执行以下任务：\n\n搜索微信公众号上关于「AI Agent」的最新文章，返回3篇即可\n\n执行完成后，请明确说明完成状态和关键输出。",
      "expected_behaviors": ["调用weixin_search", "返回文章列表", "有文章标题"],
      "assertions": [
        {"type": "regex", "name": "有文章列表", "pattern": "标题|文章|篇"},
        {"type": "contains", "name": "覆盖话题", "value": "Agent"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 180,
      "notes": "2026-03-21：断言检查文章列表而非http链接，因为技能规范要求不展示临时链接"
    },
    {
      "scenario_id": "hf-qingshuang-001",
      "skill_name": "qingshuang-research-style",
      "display_name": "qingshuang-research-style（清爽调研风格）",
      "description": "清爽调研报告风格应用测试",
      "prompt": "[测试模式] 请使用 qingshuang-research-style 技能执行以下任务：\n\n请说明清爽调研报告风格的核心CSS特点和设计规范\n\n执行完成后，请明确说明完成状态和关键输出。",
      "expected_behaviors": ["提及CSS规范", "视觉设计说明", "色彩方案"],
      "assertions": [
        {"type": "regex", "name": "提及样式", "pattern": "CSS|样式|风格|颜色"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 120
    },
    {
      "scenario_id": "hf-ai-image-001",
      "skill_name": "ai-image-generator",
      "display_name": "ai-image-generator（AI生图）",
      "description": "AI生图基础功能测试",
      "prompt": "[测试模式] 请使用 ai-image-generator 技能执行以下任务：\n\n生成一张简单的图片：一只可爱的小猫在看星空\n\n执行完成后，请明确说明完成状态、图片路径或链接。",
      "expected_behaviors": ["调用生图API", "返回图片路径或链接"],
      "assertions": [
        {"type": "regex", "name": "图片输出", "pattern": "\\.(jpg|jpeg|png|webp)"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 300
    },
    {
      "scenario_id": "hf-translate-001",
      "skill_name": "baoyu-translate",
      "display_name": "baoyu-translate（翻译）",
      "description": "英译中基础测试",
      "prompt": "[测试模式] 请使用 baoyu-translate 技能执行以下任务：\n\n翻译以下内容为中文：\nThe future of software development is AI-powered coding assistants that can understand context and write high-quality code.\n\n执行完成后，请明确说明完成状态和翻译结果。",
      "expected_behaviors": ["准确翻译", "术语恰当"],
      "assertions": [
        {"type": "regex", "name": "翻译关键词", "pattern": "AI|代码|助手|编程"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 120
    },
    {
      "scenario_id": "hf-kim-docs-001",
      "skill_name": "ks-kim-docs-shuttle",
      "display_name": "ks-kim-docs-shuttle（KIM文档同步）",
      "description": "KIM Docs读取测试",
      "prompt": "[测试模式] 请使用 ks-kim-docs-shuttle 技能执行以下任务：\n\n列出我在KIM Docs中最近的文档列表\n\n执行完成后，请明确说明完成状态和文档列表。",
      "expected_behaviors": ["获取文档列表", "显示文档信息"],
      "assertions": [
        {"type": "regex", "name": "有文档", "pattern": "文档|Docs|docs"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 180
    },
    {
      "scenario_id": "hf-humanize-001",
      "skill_name": "humanize-writing",
      "display_name": "humanize-writing（去AI味）",
      "description": "文本人性化改写测试",
      "prompt": "[测试模式] 请使用 humanize-writing 技能执行以下任务：\n\n请把这段文字改得更自然、更有人情味：\n「人工智能技术正在深刻改变人类社会的方方面面，其影响是深远而广泛的，具有重要的战略意义。」\n\n执行完成后，请明确说明完成状态和改写结果。",
      "expected_behaviors": ["识别AI模式", "提供改写版本", "更自然的表达"],
      "assertions": [
        {"type": "contains", "name": "执行改写", "value": "改写"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 120
    },
    {
      "scenario_id": "hf-html-screenshot-001",
      "skill_name": "html-screenshot",
      "display_name": "html-screenshot（HTML截图）",
      "description": "HTML渲染截图测试",
      "prompt": "[测试模式] 请使用 html-screenshot 技能执行以下任务：\n\n把这段HTML渲染为PNG截图：\n<html><body style=\"padding:20px;background:#f5f5f5;\"><h1 style=\"color:#333;\">测试标题</h1><p>这是测试内容</p></body></html>\n\n执行完成后，请明确说明完成状态和截图路径。",
      "expected_behaviors": ["渲染HTML", "输出PNG文件"],
      "assertions": [
        {"type": "regex", "name": "PNG输出", "pattern": "\\.png"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 300
    },
    {
      "scenario_id": "hf-md-to-html-001",
      "skill_name": "baoyu-markdown-to-html",
      "display_name": "baoyu-markdown-to-html（MD转HTML）",
      "description": "Markdown转HTML测试",
      "prompt": "[测试模式] 请使用 baoyu-markdown-to-html 技能执行以下任务：\n\n把以下Markdown转成带样式的HTML：\n# 测试文档\n\n这是一段**正文**内容，包含：\n- 列表项1\n- 列表项2\n\n执行完成后，请明确说明完成状态和输出文件路径。",
      "expected_behaviors": ["转换成功", "输出HTML文件", "有样式"],
      "assertions": [
        {"type": "contains", "name": "HTML输出", "value": ".html"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 120
    },
    {
      "scenario_id": "hf-frontend-001",
      "skill_name": "frontend-design",
      "display_name": "frontend-design（前端设计）",
      "description": "前端组件设计测试",
      "prompt": "[测试模式] 请使用 frontend-design 技能执行以下任务：\n\n帮我设计一个简单的卡片组件的HTML和CSS，要求：现代简洁风格，有阴影效果\n\n执行完成后，请明确说明完成状态和代码输出。",
      "expected_behaviors": ["输出HTML代码", "输出CSS代码", "现代设计风格"],
      "assertions": [
        {"type": "regex", "name": "有CSS", "pattern": "style|css|CSS"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 180
    },
    {
      "scenario_id": "hf-pptx-001",
      "skill_name": "pptx",
      "display_name": "pptx（PPT生成）",
      "description": "PPT创建基础测试",
      "prompt": "[测试模式] 请使用 pptx 技能执行以下任务：\n\n创建一个简单的2页PPT：\n第1页：标题页，标题为「测试演示」\n第2页：内容页，包含3个要点\n\n执行完成后，请明确说明完成状态和文件路径。",
      "expected_behaviors": ["创建PPTX文件", "包含标题页", "包含内容页"],
      "assertions": [
        {"type": "regex", "name": "PPTX输出", "pattern": "\\.pptx"},
        {"type": "contains", "name": "任务完成", "value": "完成"}
      ],
      "priority": "P1",
      "timeout": 180
    }
  ]
}
