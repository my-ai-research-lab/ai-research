{
  "version": "1.0.0",
  "created_at": "2026-03-24",
  "description": "ks-design-* 四大设计技能评测场景（infographic / slide-deck / ppt / image-gen）",
  "scenarios": [
    {
      "scenario_id": "ks-design-image-gen-001",
      "skill_name": "ks-design-image-gen",
      "display_name": "ks-design-image-gen（AI生图）",
      "description": "文生图基础功能测试：生成一张科技风格配图",
      "prompt": "[测试模式] 请使用 ks-design-image-gen 技能执行以下任务：\n\n用AI生成一张图片：一个AI机器人在和人类程序员一起写代码，科技感，简洁风格\n\n执行完成后，请明确说明完成状态、图片路径或链接。",
      "expected_behaviors": [
        "识别 AI生图 触发词并加载 ks-design-image-gen 技能",
        "调用图片生成 API（Siliconflow / DesignAI）",
        "返回可访问的图片 URL 或本地路径",
        "图片与描述主题相关"
      ],
      "assertions": [
        {
          "type": "regex",
          "name": "包含图片URL或路径",
          "pattern": "(https?://[^\\s]+\\.(jpg|png|webp|jpeg)|/[^\\s]+\\.(jpg|png|webp|jpeg))"
        },
        {
          "type": "regex",
          "name": "提到生成或完成",
          "pattern": "生成|完成|图片|已生成"
        }
      ],
      "artifact_extractors": [
        {
          "name": "生成图片",
          "type": "url",
          "pattern": "https?://[^\\s]+\\.(png|jpg|jpeg|webp)",
          "description": "AI生成的图片链接"
        }
      ],
      "priority": "P1",
      "timeout": 300
    },
    {
      "scenario_id": "ks-design-infographic-001",
      "skill_name": "ks-design-infographic",
      "display_name": "ks-design-infographic（信息图）",
      "description": "信息图生成基础功能测试：生成一张 AI 技术演进信息图",
      "prompt": "[测试模式] 请使用 ks-design-infographic 技能执行以下任务：\n\n生成一张信息图，主题：「2024-2025年AI大模型技术演进」，包含GPT-4、Claude 3、Gemini等关键节点，时间线风格\n\n执行完成后，请明确说明完成状态和输出的图片链接或文件路径。",
      "expected_behaviors": [
        "识别「信息图」触发词并加载 ks-design-infographic 技能",
        "分析内容并选择合适的布局（时间线/流程/对比等）",
        "选择合适的视觉风格",
        "生成高质量信息图并返回路径或链接"
      ],
      "assertions": [
        {
          "type": "regex",
          "name": "包含图片URL或路径",
          "pattern": "(https?://[^\\s]+\\.(jpg|png|webp|jpeg)|/[^\\s]+\\.(jpg|png|webp|jpeg))"
        },
        {
          "type": "regex",
          "name": "提到布局或风格选择",
          "pattern": "布局|风格|时间线|timeline|layout"
        },
        {
          "type": "regex",
          "name": "任务完成标志",
          "pattern": "完成|生成|已生成|infographic"
        }
      ],
      "artifact_extractors": [
        {
          "name": "信息图",
          "type": "url",
          "pattern": "https?://[^\\s]+\\.(png|jpg|jpeg|webp)",
          "description": "生成的信息图链接"
        }
      ],
      "priority": "P1",
      "timeout": 300
    },
    {
      "scenario_id": "ks-design-slide-deck-001",
      "skill_name": "ks-design-slide-deck",
      "display_name": "ks-design-slide-deck（幻灯片图片序列）",
      "description": "幻灯片图片序列生成测试：生成3张研发效能主题幻灯片",
      "prompt": "[测试模式] 请使用 ks-design-slide-deck 技能执行以下任务：\n\n创建3张幻灯片，主题：「研发效能提升方案」，内容：封面页 + 三大核心举措 + 预期效果。使用专业商务风格。\n\n执行完成后，请明确说明完成状态和生成的幻灯片图片链接或路径。",
      "expected_behaviors": [
        "识别「创建幻灯片」触发词并加载 ks-design-slide-deck 技能",
        "生成结构化幻灯片大纲",
        "选择合适的视觉风格和配色方案",
        "调用 AI 生成幻灯片图片序列",
        "返回图片链接或文件路径"
      ],
      "assertions": [
        {
          "type": "regex",
          "name": "包含图片输出",
          "pattern": "(https?://[^\\s]+\\.(jpg|png|webp|jpeg)|/[^\\s]+\\.(jpg|png|webp|jpeg))"
        },
        {
          "type": "regex",
          "name": "提到风格或大纲",
          "pattern": "风格|大纲|幻灯片|slide|封面"
        },
        {
          "type": "regex",
          "name": "任务完成标志",
          "pattern": "完成|生成|已生成"
        }
      ],
      "artifact_extractors": [
        {
          "name": "幻灯片图片",
          "type": "url",
          "pattern": "https?://[^\\s]+\\.(png|jpg|jpeg|webp)",
          "description": "生成的幻灯片图片链接"
        }
      ],
      "priority": "P1",
      "timeout": 600
    },
    {
      "scenario_id": "ks-design-ppt-001",
      "skill_name": "ks-design-ppt",
      "display_name": "ks-design-ppt（工作汇报PPT）",
      "description": "工作汇报风格 PPT 生成测试：生成一份季度工作汇报",
      "prompt": "[测试模式] 请使用 ks-design-ppt 技能执行以下任务：\n\n生成一份工作汇报PPT，主题：「研发团队Q1工作总结」，包含：封面页、工作亮点（3条）、数据成果（准确率98%、效率提升2.5倍、覆盖场景120+）、下季度计划（3点）、结尾页。使用工作汇报风格（模式A），基于快手内部演示规范配色。\n\n执行完成后，请明确说明完成状态和生成的 .pptx 文件路径。",
      "expected_behaviors": [
        "识别「工作汇报PPT」触发词并加载 ks-design-ppt 技能，选择模式A",
        "使用 PptxGenJS 生成 .pptx 文件",
        "应用工作汇报配色方案（暖橙 #F96700 等）",
        "包含封面、内容、数据展示、结尾等页面",
        "返回 .pptx 文件路径"
      ],
      "assertions": [
        {
          "type": "regex",
          "name": "包含 pptx 文件路径",
          "pattern": "\\.pptx"
        },
        {
          "type": "regex",
          "name": "提到配色或布局",
          "pattern": "配色|布局|封面|F96700|暖橙|PptxGenJS|pptxgenjs"
        },
        {
          "type": "regex",
          "name": "任务完成标志",
          "pattern": "完成|生成|已生成"
        }
      ],
      "artifact_extractors": [
        {
          "name": "PPT文件",
          "type": "file",
          "pattern": "[^\\s]+\\.pptx",
          "description": "生成的 .pptx 文件路径"
        }
      ],
      "priority": "P1",
      "timeout": 600
    }
  ]
}
