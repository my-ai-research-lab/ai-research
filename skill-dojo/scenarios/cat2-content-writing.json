{
  "version": "1.0.0",
  "created_at": "2026-03-20",
  "description": "Cat2 内容写作分类评测场景（10个技能）",
  "scenarios": [
    {"scenario_id": "cat2-column-writer-001", "skill_name": "sl-ai-column-writer", "display_name": "sl-ai-column-writer（专栏写作）", "description": "查看专栏写作技能配置", "prompt": "请告诉我专栏写作技能的当前状态和下一期计划", "expected_behaviors": ["加载专栏配置", "说明写作规范"], "assertions": [{"type": "contains", "name": "提及专栏", "value": "专栏"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-copywriting-001", "skill_name": "copywriting", "display_name": "copywriting（营销文案）", "description": "生成转化文案", "prompt": "帮我写一段AI编程工具的营销文案，50字以内", "expected_behaviors": ["输出简洁有力的文案", "有转化导向"], "assertions": [{"type": "contains", "name": "AI相关", "value": "AI"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-humanize-001", "skill_name": "humanize-writing", "display_name": "humanize-writing（去AI味）", "description": "润色文本去AI痕迹", "prompt": "请把这段文字改得更自然：「人工智能技术正在深刻改变人类社会的方方面面，其影响是深远的。」", "expected_behaviors": ["消除AI模式化表达", "更自然流畅"], "assertions": [{"type": "not_contains", "name": "去掉套话", "value": "方方面面"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-translate-001", "skill_name": "baoyu-translate", "display_name": "baoyu-translate（翻译）", "description": "翻译英文到中文", "prompt": "翻译：The future of AI is autonomous agents that can reason and act.", "expected_behaviors": ["准确翻译", "术语恰当"], "assertions": [{"type": "contains", "name": "翻译智能体", "value": "智能体"}, {"type": "not_contains", "name": "无原文", "value": "The future"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-format-md-001", "skill_name": "baoyu-format-markdown", "display_name": "baoyu-format-markdown（Markdown格式化）", "description": "格式化Markdown文本", "prompt": "帮我格式化这段文字为Markdown：AI Agent是能够自主完成任务的智能体 它可以感知环境并采取行动", "expected_behaviors": ["添加标题", "分段", "格式化"], "assertions": [{"type": "contains", "name": "有标题", "value": "#"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-md-to-html-001", "skill_name": "baoyu-markdown-to-html", "display_name": "baoyu-markdown-to-html（MD转HTML）", "description": "将Markdown转为HTML", "prompt": "把这段Markdown转成HTML：# 标题\n这是正文内容。", "expected_behaviors": ["输出HTML", "样式美观"], "assertions": [{"type": "contains", "name": "HTML标签", "value": "<h1>"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-promotion-coaching-001", "skill_name": "ks-promotion-coaching", "display_name": "ks-promotion-coaching（晋升辅导）", "description": "查看晋升辅导功能", "prompt": "请说明晋升辅导技能的使用流程", "expected_behaviors": ["说明辅导流程", "提及材料和PPT"], "assertions": [{"type": "contains", "name": "提及晋升", "value": "晋升"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-promotion-review-001", "skill_name": "ks-promotion-review-sabcd", "display_name": "ks-promotion-review-sabcd（晋升评审）", "description": "对材料做SABCD评审", "prompt": "请说明晋升评审SABCD评级的标准", "expected_behaviors": ["说明SABCD五档", "说明评审维度"], "assertions": [{"type": "contains", "name": "SABCD", "value": "SABCD"}], "priority": "P1", "timeout": 60},
    {"scenario_id": "cat2-executive-report-001", "skill_name": "executive-report-writing", "display_name": "executive-report-writing（高管汇报）", "description": "了解高管汇报规范", "prompt": "请说明给高管写汇报材料的核心要求", "expected_behaviors": ["强调逻辑清晰", "结构化表达"], "assertions": [{"type": "contains", "name": "逻辑", "value": "逻辑"}], "priority": "P2", "timeout": 60},
    {"scenario_id": "cat2-personal-assistant-001", "skill_name": "personal-assistant", "display_name": "personal-assistant（个人助手）", "description": "查看个人助手功能", "prompt": "请说明个人助手技能能做什么", "expected_behaviors": ["说明日程管理", "任务追踪等功能"], "assertions": [{"type": "contains", "name": "任务", "value": "任务"}], "priority": "P2", "timeout": 60}
  ]
}
